PHOENIX_DB_PATH=.phoenix/phoenix.db
PHOENIX_REPO_PATH=.
PHOENIX_MAIN_BRANCH=main
PHOENIX_REMOTE_NAME=origin
PHOENIX_EXECUTOR_CMD=
PHOENIX_EXECUTOR_TIMEOUT_SEC=1800
PHOENIX_QUALITY_GATE_TIMEOUT_SEC=1200
PHOENIX_AUTO_PROCESS_ON_SUBMIT=true
PHOENIX_AUTO_MERGE=true
PHOENIX_CI_POLL_INTERVAL_SEC=30
PHOENIX_QUEUE_POLL_INTERVAL_SEC=20
PHOENIX_SERVICE_NAME=PhoenixAgent
PHOENIX_HEALTHCHECK_URL=http://127.0.0.1:8000/health
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=
